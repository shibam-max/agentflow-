# ── LLM API Keys (at least one required) ─────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth ──────────────────────────────────────────────────────────────
# Min 32 characters for HMAC-SHA256
JWT_SECRET=change-me-to-a-long-random-string-in-production

# ── Database ──────────────────────────────────────────────────────────
POSTGRES_PASSWORD=localpass
# Overridden automatically by docker-compose service names
POSTGRES_URL=jdbc:postgresql://localhost:5432/agentflow
POSTGRES_USER=agentflow

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Service URLs (set automatically in docker-compose) ────────────────
ORCHESTRATOR_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── AWS (only needed for cloud deploy) ────────────────────────────────
# AWS_REGION=us-east-1
# AWS_ACCOUNT_ID=123456789012
